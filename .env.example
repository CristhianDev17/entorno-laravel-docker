# Ruta absoluta a tu proyecto Laravel
# Windows: C:/Users/TuUsuario/Desktop/ProyectoERP
# Linux/Mac: /home/usuario/projects/ProyectoERP
PROJECT_PATH=

# Puertos de la aplicación
APP_PORT=8000
PMA_PORT=8080
DB_PORT=3306

# Configuración de base de datos
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret